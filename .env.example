# ════════════════════════════════════════════════════════════════════════════
# AIDEVIX MOBILE — .env namunasi (Expo / React Native)
# ────────────────────────────────────────────────────────────────────────────
# Tezda boshlash:
#   1) Windows:  copy .env.example .env
#      macOS/Linux:  cp .env.example .env
#   2) Quyidagi qiymatlarni o'zingiznikiga moslashtiring.
#   3) `npx expo start -c` (cache tozalash bilan) — env o'zgarishi yangilanishi uchun.
#
# DIQQAT: Faqat `EXPO_PUBLIC_` prefiksli o'zgaruvchilar runtime'da mavjud bo'ladi.
# Prefiksiz o'zgaruvchilar bundle'ga kirmaydi.
# ════════════════════════════════════════════════════════════════════════════

# ─── Backend API ───────────────────────────────────────────────────────────
# Production (Railway) — telefon va kompyuter har xil tarmoqda bo'lsa ham ishlaydi:
EXPO_PUBLIC_API_URL=https://aidevix-backend-production.up.railway.app
EXPO_PUBLIC_API_PREFIX=/api

# Local backend (telefon + kompyuter BIR XIL Wi-Fi'da bo'lishi shart):
#   `auto` = Metro bundler host IP'si avtomatik aniqlanadi. IP/Wi-Fi o'zgarsa ham
#   `.env` ni qo'lda yangilash SHART EMAS. Yuqoridagi 2 satrni kommentga oling:
# EXPO_PUBLIC_API_URL=auto
# EXPO_PUBLIC_API_PORT=5000          # local backend porti
# EXPO_PUBLIC_API_PREFIX=/api
#
# (Eski usul — IP'ni qo'lda yozish ham mumkin: `ipconfig`/`ifconfig` bilan oling)
# EXPO_PUBLIC_API_URL=http://192.168.x.x:5000

# ─── Social Links ──────────────────────────────────────────────────────────
EXPO_PUBLIC_TELEGRAM_CHANNEL=https://t.me/aidevix
EXPO_PUBLIC_TELEGRAM_BOT=https://t.me/aidevix_bot
EXPO_PUBLIC_INSTAGRAM_URL=https://instagram.com/aidevix

# ─── Push Notifications (Expo) ─────────────────────────────────────────────
# expo.dev → loyiha sahifasidan EAS projectId'ni oling.
# Local dev'da bo'sh qoldirsa ham ilova ishlaydi, push faqat ishlamaydi.
EXPO_PUBLIC_PROJECT_ID=your-eas-project-id
