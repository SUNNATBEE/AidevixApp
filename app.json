{
  "expo": {
    "name": "Aidevix",
    "slug": "aidevixapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aidevix",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aidevix.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.aidevix.app"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.149350644359-ktgp3aj2qomavd6v5nfn1t7h152746fa"
        }
      ]
    ],
    "extra": {
      "googleAuth": {
        "webClientId": "149350644359-e5vpjgb99qlacpiadolifnae76qh65d8.apps.googleusercontent.com",
        "androidClientId": "149350644359-656al7pgio9f81j4374pvtndmnmq4adv.apps.googleusercontent.com",
        "iosClientId": "149350644359-ktgp3aj2qomavd6v5nfn1t7h152746fa.apps.googleusercontent.com"
      },
      "router": {},
      "eas": {
        "projectId": "cc775564-4657-47bf-891c-5de62de12a30"
      }
    },
    "owner": "abduvoris777"
  }
}
