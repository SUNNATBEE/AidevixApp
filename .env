# ============================================
# AIDEVIX Mobile — local development .env

# ============================================
# Fizik telefon (Expo Go) — kompyuter LAN IP'si
# Telefon va kompyuter BIR XIL Wi-Fi tarmoqda bo'lishi shart.
# Kompyuter IP o'zgarsa (yangi Wi-Fi, restart) — bu yerni yangilang.

# --- Backend API (LOCAL — kompyuter LAN IP) ---
# Telefon + kompyuter BIR XIL Wi-Fi tarmoqda bo'lishi shart.
EXPO_PUBLIC_API_URL=http://192.168.81.214:5000
EXPO_PUBLIC_API_PREFIX=/api

# Production (Railway) — ustoz deploy qilganda quyidagini ishlating:
# EXPO_PUBLIC_API_URL=https://aidevix-backend-production.up.railway.app
# EXPO_PUBLIC_API_PREFIX=/api

# --- Social Links ---
EXPO_PUBLIC_TELEGRAM_CHANNEL=https://t.me/aidevix
EXPO_PUBLIC_TELEGRAM_BOT=https://t.me/aidevix_bot
EXPO_PUBLIC_INSTAGRAM_URL=https://instagram.com/aidevix

# --- Push Notifications (Expo) ---
# expo.dev'dan olingan EAS projectId
EXPO_PUBLIC_PROJECT_ID=f000-0000-0000-0000
